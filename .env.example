# Copy to `.env` and fill in. Never commit the real `.env`.
# All secrets are read from the environment — never hard-coded (PRD #1, AC).

# Postgres — the single source of truth (ADR-0003).
DATABASE_URL=postgresql://user:password@localhost:5432/health_bok

# LLM provider for the four chat tasks — summarize, extract, answer, judge
# (ADR-0012). `openai` (default) keeps the whole system on one external LLM
# provider, since OpenAI is already needed for embeddings + Whisper below.
# Set `anthropic` to run those tasks on Claude instead.
LLM_PROVIDER=openai
# Claude API key — required ONLY when LLM_PROVIDER=anthropic. Leave unset on OpenAI.
# ANTHROPIC_API_KEY=sk-ant-...
# Model used to summarize a Transcript for the Digest (cost vs quality). Optional;
# defaults to the provider's default chat model (OpenAI: gpt-4.1). Renamed from the
# old CLAUDE_MODEL.
SUMMARY_MODEL=gpt-4.1
# Map-reduce thresholds for long videos (issue #6). Optional — both default if
# unset. Transcripts longer than SUMMARY_MAX_CHARS characters are split into
# SUMMARY_CHUNK_CHARS-sized sections, summarized, then reduced into one Summary.
SUMMARY_MAX_CHARS=48000
SUMMARY_CHUNK_CHARS=16000

# Backfill recency window (issue #7). Optional — defaults to 730 days (~2 years).
# When a Creator is added, its uploads published within this many days are seeded
# as metadata-only Candidates; older ones are skipped.
BACKFILL_CUTOFF_DAYS=730

# Resend — powers the DigestSender port. The Digest is only a notification
# (ADR-0007). Set DIGEST_ENABLED=false to run with email off, in which case the
# three RESEND/DIGEST_* values below are not required.
DIGEST_ENABLED=true
RESEND_API_KEY=re_...
DIGEST_FROM="Health Digest <digest@yourdomain.com>"
DIGEST_RECIPIENT=you@example.com

# OpenAI — Whisper transcription (daily path) AND Concept-mention embeddings
# (ADR-0008). One key serves both.
OPENAI_API_KEY=sk-...

# --- Part 2: Web App & Knowledge Graph (issue #13) -------------------------
# Model for Claim/Protocol extraction (ADR-0010). Optional; defaults to the
# provider's default chat model. May differ from SUMMARY_MODEL — precision-first
# extraction can warrant a stronger model than bulk summarization.
EXTRACTION_MODEL=gpt-4.1
# Embedding model for Concept normalization (ADR-0008). Optional; 1536-d. Always
# OpenAI, independent of LLM_PROVIDER.
EMBEDDING_MODEL=text-embedding-3-small
# Cosine-distance threshold below which two Concept mentions are merged. Optional;
# defaults to 0.15. Lower = stricter (fewer merges); higher = more merging.
CONCEPT_MERGE_DISTANCE=0.15
# Grounded natural-language query (issue #17, ADR-0011). All optional.
# Model used to synthesize answers; defaults to the provider's default chat model.
QUERY_MODEL=gpt-4.1
# Cosine-distance cutoff beyond which a Concept does not cover a question — the
# abstention knob. Defaults to 0.6; lower = abstains more readily.
QUERY_MAX_DISTANCE=0.6
# Impact engine — bidirectional change detection (issue #18). All optional.
# Model the StanceJudge uses to assign a Stance; defaults to the provider's default
# chat model. May differ from EXTRACTION_MODEL / QUERY_MODEL.
STANCE_MODEL=gpt-4.1
# Per-category cap on candidates one detection pass judges — the ceiling on LLM
# judge calls per admitted entity or recorded anchor. Defaults to 25.
IMPACT_CANDIDATE_LIMIT=25
# Public base URL of the Web App, for Digest deep-links into the review queue
# (ADR-0007). Optional; usually your Tailscale address, e.g. http://bok:3000.
WEBAPP_BASE_URL=http://localhost:3000

# --- docker-compose only ---------------------------------------------------
# Postgres password for the bundled db service (compose composes DATABASE_URL).
POSTGRES_PASSWORD=health
# Base URL the browser uses to reach the API; your tailnet address in production.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
