# Copy to `.env` and fill in. Never commit the real `.env`.
# All secrets are read from the environment — never hard-coded (PRD #1, AC).

# Postgres — the single source of truth (ADR-0003).
DATABASE_URL=postgresql://user:password@localhost:5432/health_bok

# Claude API — powers the Summarizer port.
ANTHROPIC_API_KEY=sk-ant-...
# Configurable summarization model (cost vs quality). Default: claude-sonnet-4-6.
CLAUDE_MODEL=claude-sonnet-4-6
# Map-reduce thresholds for long videos (issue #6). Optional — both default if
# unset. Transcripts longer than SUMMARY_MAX_CHARS characters are split into
# SUMMARY_CHUNK_CHARS-sized sections, summarized, then reduced into one Summary.
SUMMARY_MAX_CHARS=48000
SUMMARY_CHUNK_CHARS=16000

# Resend — powers the DigestSender port.
RESEND_API_KEY=re_...
DIGEST_FROM="Health Digest <digest@yourdomain.com>"
DIGEST_RECIPIENT=you@example.com

# OpenAI Whisper — transcribes caption-less videos on the daily path.
OPENAI_API_KEY=sk-...
